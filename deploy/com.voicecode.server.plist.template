<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Rendered by the deploy plugin: __UV__ = absolute path to uv,
     __REPO__ = absolute path to the voice-code checkout, __HOME__ = user home. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.voicecode.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>__UV__</string>
        <string>run</string>
        <string>--project</string>
        <string>__REPO__</string>
        <string>python</string>
        <string>-m</string>
        <string>voicecode.server</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__REPO__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.voicecode/logs/server.out.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.voicecode/logs/server.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>
</dict>
</plist>
